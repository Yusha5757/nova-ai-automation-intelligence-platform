    {
      "parameters": {
        "jsCode": "const base = $('Route - Security and Intent').first().json;\nconst message = String(base.chat_input ?? '').toLowerCase();\nconst queryWords = new Set(\n  message\n    .replace(/[^a-z0-9\\s_-]/g, ' ')\n    .split(/\\s+/)\n    .filter(word => word.length >= 3)\n);\n\nconst entries = $input.all()\n  .map(item => item.json)\n  .filter(row => row && row.title && row.content);\n\nfunction score(entry) {\n  const category = String(entry.category ?? '').toLowerCase();\n  const title = String(entry.title ?? '').toLowerCase();\n  const content = String(entry.content ?? '').toLowerCase();\n  const tags = Array.isArray(entry.tags)\n    ? entry.tags.map(String).join(' ').toLowerCase()\n    : String(entry.tags ?? '').toLowerCase();\n\n  let points = Number(entry.priority ?? 0);\n\n  if (category === base.route) points += 25;\n  if (category === 'general') points += 5;\n\n  for (const word of queryWords) {\n    if (title.includes(word)) points += 5;\n    if (tags.includes(word)) points += 4;\n    if (content.includes(word)) points += 1;\n  }\n\n  return points;\n}\n\nconst selected = entries\n  .map(entry => ({ entry, score: score(entry) }))\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 6)\n  .map(({ entry }) => entry);\n\nconst knowledgeContext = selected.length\n  ? selected\n      .map((entry, index) =>\n        `[KNOWLEDGE ${index + 1}] ${entry.title}\\nCategory: ${entry.category}\\n${entry.content}`\n      )\n      .join('\\n\\n')\n  : 'No curated knowledge-base entries matched this request.';\n\nconst agentPrompt = `\nCURRENT USER MESSAGE\n${base.chat_input}\n\nDURABLE CONVERSATION HISTORY\n${base.durable_history}\n\nCURATED PRODUCT KNOWLEDGE\n${knowledgeContext}\n\nROUTING INFORMATION\nRoute: ${base.route}\nReason: ${base.route_reason}\n\nAnswer the current user message. Use earlier history only when it is genuinely relevant.\n`.trim();\n\nreturn [{\n  json: {\n    ...base,\n    knowledge_context: knowledgeContext,\n    agent_prompt: agentPrompt,\n  }\n}];"
      },

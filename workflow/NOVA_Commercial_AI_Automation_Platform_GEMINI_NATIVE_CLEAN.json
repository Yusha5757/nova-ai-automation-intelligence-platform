      "id": "1627ff59-a7fa-4a2d-a24a-d00e5df0aa87",
      "name": "Supabase - Load Knowledge Base",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        -300,
        120
      ],
      "credentials": {
        "supabaseApi": {

      "id": "0304ee10-869e-4a9c-858d-8faf184fe28d",
      "name": "Supabase - Load Session History",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        -1020,
        0
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SELECT_YOUR_EXISTING_SUPABASE_CREDENTIAL",
          "name": "Supabase API"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const base = $('Security - Normalize Input').first().json;\n\nconst historyRows = $input.all()\n  .map(item => item.json)\n  .filter(row => row && row.id && row.created_at);\n\nconst oneHourAgo = new Date(base.rate_window_start).getTime();\n\nconst requestsInWindow = historyRows.filter(row => {\n  const timestamp = new Date(row.created_at).getTime();\n  return Number.isFinite(timestamp) && timestamp >= oneHourAgo;\n}).length;\n\nconst durableHistory = historyRows\n  .slice(0, 10)\n  .reverse()\n  .map(row => {\n    const user = String(row.user_message ?? '').slice(0, 900);\n    const assistant = String(row.assistant_message ?? '').slice(0, 1400);\n    return `USER: ${user}\\nASSISTANT: ${assistant}`;\n  })\n  .join('\\n\\n');\n\nlet status = 'allowed';\nlet blockReason = '';\n\nif (base.validation_error === 'empty_message') {\n  status = 'blocked';\n  blockReason = 'Please enter a message before sending.';\n} else if (base.validation_error === 'message_too_long') {\n  status = 'blocked';\n  blockReason = 'Your message is longer than 4,000 characters. Please shorten it and try again.';\n} else if (requestsInWindow >= 30) {\n  status = 'blocked';\n  blockReason = 'This session has reached the hourly message limit. Please wait before sending another message.';\n}\n\nconst message = String(base.chat_input ?? '').toLowerCase();\n\nconst technicalPattern =\n  /\\b(api|webhook|json|sql|supabase|database|schema|rls|oauth|authentication|security|debug|error|bug|architecture|code|javascript|python|node|server|deployment|docker|latency|scaling|integration)\\b/i;\n\nconst strategyPattern =\n  /\\b(price|pricing|proposal|client|customer|sell|sales|market|business|roi|package|offer|freelance|agency|revenue|scope|discovery|portfolio|positioning|contract)\\b/i;\n\nlet route = 'general';\nlet routeReason = 'General automation advisory request';\n\nif (technicalPattern.test(message)) {\n  route = 'technical';\n  routeReason = 'Technical or implementation language detected';\n} else if (strategyPattern.test(message)) {\n  route = 'strategy';\n  routeReason = 'Commercial or productization language detected';\n}\n\nreturn [{\n  json: {\n    ...base,\n    status,\n    block_reason: blockReason,\n    route,\n    route_reason: routeReason,\n    requests_in_last_hour: requestsInWindow,\n    durable_history: durableHistory || 'No durable conversation history exists yet.',\n  }\n}];"
      },

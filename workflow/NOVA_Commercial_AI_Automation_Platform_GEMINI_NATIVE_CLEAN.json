    {
      "parameters": {
        "jsCode": "const end = new Date();\nconst start = new Date(end.getTime() - 24 * 60 * 60 * 1000);\n\nreturn [{\n  json: {\n    report_date: end.toISOString().slice(0, 10),\n    window_start: start.toISOString(),\n    window_end: end.toISOString(),\n  }\n}];"
      },
      "id": "0abfd6cf-5f13-40ed-bf92-5b86dcadf998",
      "name": "Analytics - Set Reporting Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1260,
        1120
      ]
    },
    {
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "ai_conversations",
        "returnAll": false,
        "limit": 500,
        "orderBy": "created_at.desc",
        "filterType": "string",
        "filterString": "={{ 'created_at=gte.' + $json.window_start }}"
      },
      "id": "6120163e-7745-49bd-af7a-df6891ef49aa",
      "name": "Supabase - Load Daily Conversations",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        -1020,
        1120
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SELECT_YOUR_EXISTING_SUPABASE_CREDENTIAL",
          "name": "Supabase API"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const window = $('Analytics - Set Reporting Window').first().json;\nconst rows = $input.all()\n  .map(item => item.json)\n  .filter(row => row && row.id);\n\nconst routeCounts = { general: 0, technical: 0, strategy: 0, blocked: 0 };\nconst sessions = new Set();\nconst riskCounts = {};\n\nfor (const row of rows) {\n  if (routeCounts[row.route] !== undefined) routeCounts[row.route] += 1;\n  sessions.add(row.session_id);\n\n  const flags = Array.isArray(row.risk_flags) ? row.risk_flags : [];\n  for (const flag of flags) {\n    riskCounts[flag] = (riskCounts[flag] ?? 0) + 1;\n  }\n}\n\nconst samples = rows\n  .filter(row => row.route !== 'blocked')\n  .slice(0, 20)\n  .map(row => ({\n    route: row.route,\n    user_message: String(row.user_message ?? '').slice(0, 400),\n  }));\n\nconst metrics = {\n  total_messages: rows.length,\n  unique_sessions: sessions.size,\n  route_counts: routeCounts,\n  blocked_rate: rows.length ? Number((routeCounts.blocked / rows.length).toFixed(4)) : 0,\n  risk_flags: riskCounts,\n  window_start: window.window_start,\n  window_end: window.window_end,\n};\n\nconst prompt = `\nCreate a concise daily product-intelligence report for an AI automation chatbot.\n\nMETRICS\n${JSON.stringify(metrics, null, 2)}\n\nSAMPLE USER REQUESTS\n${JSON.stringify(samples, null, 2)}\n\nReturn:\n1. Executive Summary\n2. What Users Wanted\n3. Friction or Failure Signals\n4. Product and Sales Opportunities\n5. Knowledge-Base Gaps\n6. Three Actions for Tomorrow\n\nDo not invent evidence outside these metrics and samples.\n`.trim();\n\nreturn [{\n  json: {\n    report_date: window.report_date,\n    metrics,\n    prompt,\n  }\n}];"
      },
      "id": "b1b93a31-6453-4d19-9d91-5c02cbd6e097",
      "name": "Analytics - Aggregate Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -780,

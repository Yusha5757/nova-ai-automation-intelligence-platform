      "id": "c5902d48-7eb9-4261-8ebb-44ef2b95bfc6",
      "name": "Chat Trigger - Product Assistant",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [
        -1500,
        0
      ],
      "webhookId": "90c57b39-a403-4c23-91c5-4970bb4a3827"
    },
    {
      "parameters": {
        "jsCode": "const incoming = $input.first()?.json ?? {};\n\nconst rawMessage =\n  incoming.chatInput ??\n  incoming.body?.chatInput ??\n  incoming.message ??\n  incoming.body?.message ??\n  '';\n\nconst normalizedMessage = String(rawMessage)\n  .normalize('NFKC')\n  .replace(/\\u0000/g, '')\n  .replace(/\\r\\n/g, '\\n')\n  .trim();\n\nconst rawSession = String(\n  incoming.sessionId ??\n  incoming.body?.sessionId ??\n  incoming.session_id ??\n  $execution.id\n);\n\nlet safeSession = rawSession\n  .replace(/[^a-zA-Z0-9_-]/g, '')\n  .slice(0, 128);\n\nif (safeSession.length < 8) {\n  safeSession = `session_${String($execution.id).replace(/[^a-zA-Z0-9_-]/g, '')}`;\n}\n\nconst MAX_MESSAGE_LENGTH = 4000;\nlet validationError = '';\n\nif (!normalizedMessage) {\n  validationError = 'empty_message';\n} else if (normalizedMessage.length > MAX_MESSAGE_LENGTH) {\n  validationError = 'message_too_long';\n}\n\nconst auditPatterns = [\n  { name: 'secret_exfiltration', regex: /(show|reveal|print|return).{0,40}(api key|secret|credential|service role|system prompt)/i },\n  { name: 'instruction_override', regex: /(ignore|override|disregard).{0,30}(previous|system|developer|safety|instructions)/i },\n  { name: 'encoded_payload', regex: /(base64|decode this|javascript:|<script)/i },\n  { name: 'destructive_request', regex: /(drop table|delete all|truncate table|disable security|bypass rls)/i },\n];\n\nconst riskFlags = auditPatterns\n  .filter(({ regex }) => regex.test(normalizedMessage))\n  .map(({ name }) => name);\n\nconst now = new Date();\n\nreturn [{\n  json: {\n    chat_input: normalizedMessage.slice(0, MAX_MESSAGE_LENGTH),\n    session_id: safeSession,\n    request_id: `${$execution.id}-${Date.now()}`,\n    received_at: now.toISOString(),\n    rate_window_start: new Date(now.getTime() - 60 * 60 * 1000).toISOString(),\n    validation_error: validationError,\n    risk_flags: riskFlags,\n    source: 'premium_web_chat',\n    action: incoming.action ?? incoming.body?.action ?? 'sendMessage',\n    client_metadata: {\n      page: incoming.metadata?.page ?? '',\n      locale: incoming.metadata?.locale ?? '',\n      timezone: incoming.metadata?.timezone ?? '',\n      user_agent: incoming.metadata?.userAgent ?? '',\n    },\n  }\n}];"
      },
      "id": "f6191918-7f52-404b-a6d8-be5505e25400",
      "name": "Security - Normalize Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1260,
